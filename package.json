{
  "name": "ibanforge",
  "version": "1.0.0",
  "description": "IBANforge — IBAN validation & BIC/SWIFT lookup API with x402 micropayments and MCP",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "db:seed": "tsx src/db/seed.ts",
    "db:enrich": "tsx scripts/enrich-countries.ts",
    "mcp": "tsx src/mcp/server.ts",
    "docker:build": "docker build -t ibanforge .",
    "docker:run": "docker run -p 3000:3000 --env-file .env ibanforge",
    "check": "npm run typecheck && npm run lint && npm run test"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@x402/hono": "latest",
    "better-sqlite3": "^11.0.0",
    "hono": "^4.7.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.17.0",
    "eslint": "^10.1.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
