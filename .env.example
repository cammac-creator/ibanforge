# Server
PORT=3000
NODE_ENV=development

# x402 micropayments (disabled by default — set X402_ENABLED=true to activate)
# X402_ENABLED=true
# WALLET_ADDRESS=0xYourWalletAddress
# FACILITATOR_URL=https://facilitator.x402.org

# CORS (production: restrict to frontend domain)
# CORS_ORIGIN=https://ibanforge.com

# Optional: override database paths
# DB_BIC_PATH=./data/bic.sqlite
# DB_STATS_PATH=./data/stats.sqlite
